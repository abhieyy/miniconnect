{
  "manifest_version": 3,
  "name": "MiniConnect",
  "version": "1.0.0",
  "description": "Control YouTube Music from your phone using Spotify Connect-like interface",
  "permissions": [
    "scripting",
    "tabs",
    "webRequest",
    "storage"
  ],
  "host_permissions": [
    "https://music.youtube.com/*"
  ],
  "background": {
    "service_worker": "service-worker.js"
  },
  "content_scripts": [
    {
      "matches": ["https://music.youtube.com/*"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_title": "MiniConnect",
    "default_popup": "popup.html"
  }
}
